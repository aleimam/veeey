// Veeey — Prisma schema (P1). Backbone for the storefront; traces to VEEEY_SPEC.md §4
// and VEEEY_PRD.md FR-IDs. Conventions:
//   • Money is EGP integer piastres stored as BigInt (never floats; BigInt avoids
//     Int overflow on high-value catalog + whale lifetime spend). Fields end in `Piastres`.
//   • Bilingual text fields are split `*En` / `*Ar` (FR-I18N-01).
//   • SKU is the canonical product key; legacy WP ids preserved (FR-CAT-02).
//   • Lots are the inventory spine: product × expiry × location, FEFO (FR-INV-*).
//   • Business numbers (tiers, fees, rates) are seeded config, never hard-coded (AGENTS.md).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// Enums
// ============================================================================

enum ProductKind {
  SUPPLEMENT
  DEVICE
  INJECTION
}

enum AttributeInputType {
  SINGLE_SELECT
  MULTI_SELECT
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  PRIVATE // staff-visible only; hidden from storefront, feeds, search
  ARCHIVED
}

enum LotStatus {
  LIVE
  QUARANTINE
  EXPIRED
  WRITTEN_OFF
