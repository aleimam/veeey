  AI
}

enum MovementType {
  STOCK_IN
  SALE
  RETURN
  ADJUST
  COUNT
  TRANSFER
  WRITE_OFF
  RESERVE
  RELEASE
}

// Full live-data status vocabulary (MIGRATION_FINDINGS §5) — 11 values.
// Order status is now a TEXT code backed by the editable `OrderStatusConfig`
// table (fixed 8 codes: PENDING, EDIT, HOLD, CONFIRMED, SHIPPED, DELIVERED,
// CANCELLED, REFUNDED). Behavior/effects/transitions/icons/aliases are editable.
// The OrderStatus enum was removed; codes + defaults live in src/lib/order-status.ts.

enum PaymentState {
