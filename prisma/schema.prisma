// ============================================================================
// Identity, RBAC & accounts (Auth.js models + staff/customer profiles)
// ============================================================================

// Auth.js (NextAuth) identity. Staff have a `role`; customers have a `customer` profile.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  username      String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  passwordHash  String?
  roleId        String?
  role          Role?     @relation(fields: [roleId], references: [id])
  customer      Customer?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Back-relations for "acted by staff" references
  pharmacistOrders Order[]            @relation("OrderPharmacist")
  stocktakeCounts  StocktakeCount[]
  reviewsModerated Review[]           @relation("ReviewModerator")
  departments      DepartmentMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// Phone OTP login (FR-ACC-01b). Codes are hashed; verified within `expiresAt`.
model OtpCode {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([phone])
}

model Role {
  id          String       @id @default(cuid())
  key         String       @unique
  name        String
  description String?
  users       User[]
  permissions Permission[] @relation("RolePermissions")
  createdAt   DateTime     @default(now())
}

model Permission {
  id          String       @id @default(cuid())
  key         String       @unique
  description String?
  roles       Role[]       @relation("RolePermissions")
  departments Department[] @relation("DepartmentPermissions")
}

// Departments/Teams REPLACE the single-role model (TEAM epic, owner-locked
// 2026-06-27): each department has an editable permission set; staff belong to
// one or many; effective permissions = UNION across memberships. Existing
// Roles were copied into Departments by the migration (Role/User.roleId kept
// in the DB as a non-destructive legacy fallback, no longer written).
model Department {
  id          String             @id @default(cuid())
  key         String             @unique // e.g. 'sales' drives the pharmacist picker
  nameEn      String
  nameAr      String?
  description String?
  permissions Permission[]       @relation("DepartmentPermissions")
  members     DepartmentMember[]
  createdAt   DateTime           @default(now())
}

model DepartmentMember {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([departmentId, userId])
  @@index([userId])
}

// Storefront customer profile (FR-ACC-*). 1:1 with an Auth.js User.
model Customer {
  id                    String     @id @default(cuid())
  userId                String     @unique
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName             String?
  lastName              String?
  nameAr                String?
  tierId                String?
  tier                  Tier?      @relation(fields: [tierId], references: [id])
  pointsBalance         Int        @default(0)
  lifetimeSpendPiastres BigInt     @default(0)
  referralCode          String     @unique
  referredById          String?
  referredBy            Customer?  @relation("CustomerReferrals", fields: [referredById], references: [id])
  referrals             Customer[] @relation("CustomerReferrals")
  marketingConsent      Boolean    @default(false)
  locale                String     @default("en")
  // Link to YeldnIN for special-order dedupe (INTEGRATION_CONTRACT).
  veeeyCustomerId       String?    @unique
  legacyWpId            Int?       @unique
  syncedAt              DateTime? // last WooCommerce sync write (detach detection)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  addresses         Address[]
  orders            Order[]
  wishlistLists     WishlistList[]
  compareList       CompareList?
  reviews           Review[]
  loyaltyTxns       LoyaltyTransaction[]
  returns           Return[]
  referralsMade     Referral[]              @relation("ReferralInviter")
  referralReceived  Referral?               @relation("ReferralInvitee")
  couponRedemptions CouponRedemption[]
  analyticsSessions AnalyticsSession[]
  specialOrders     SpecialOrder[]
  analyticsEvents   AnalyticsEvent[]
  playEntries       PlayEntry[]
  notifications     Notification[]
  notificationPref  NotificationPreference?
  pushSubscriptions PushSubscription[]

  @@index([tierId])
}

model Address {
  id                String   @id @default(cuid())
  customerId        String
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  governorate       String
  city              String
  area              String
  street            String?
  building          String?
  phone             String?
  isDefaultShipping Boolean  @default(false)
  isDefaultBilling  Boolean  @default(false)
  createdAt         DateTime @default(now())

  shippingOrders Order[] @relation("OrderShippingAddress")

  @@index([customerId])
}

// ============================================================================
// Pricing tiers, loyalty, referrals, coupons (FR-PRC-*)
// ============================================================================

// Tiers are admin-renameable + manually assigned; rank orders entry->top.
model Tier {
  id             String            @id @default(cuid())
  key            String            @unique // GREEN | VEEEYIP | SELECT (stable key)
  nameEn         String
  nameAr         String
  rank           Int               @unique // 1 = entry
  earnRatePerEgp Int               @default(1) // points per EGP (configurable)
  color          String?
  badge          String?
  // Optional storefront theme for this tier (Appearance). Null = use the active theme.
  themeId        String?
  theme          Theme?            @relation(fields: [themeId], references: [id], onDelete: SetNull)
  customers      Customer[]
  rules          TierProductRule[]
  createdAt      DateTime          @default(now())
}

// Storefront theme — a named set of design-token overrides (Appearance editor).
// Exactly one theme is `isActive` (the global default for guests / untiered
// viewers); tiers may point to their own theme. `isDefault` marks the built-in
// Veeey theme (cannot be deleted). `tokens` is a sparse cssVar -> value map.
model Theme {
  id        String   @id @default(cuid())
  name      String
  tokens    Json     @default("{}")
  isActive  Boolean  @default(false)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tiers     Tier[]
}

// Composable storefront landing pages (homepage-builder blocks on arbitrary URLs).
// Rendered at /[locale]/l/[slug]. `blocks` = ordered Block[] (see lib/home-layout).
model PageLayout {
  id        String   @id @default(cuid())
  slug      String   @unique
  titleEn   String
  titleAr   String?
  status    String   @default("DRAFT") // DRAFT | PUBLISHED
  blocks    Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// WooCommerce live-sync cursor + last-run state, one row per entity
// ('products' | 'customers' | 'orders'). Powers incremental `modified_after` pulls.
model WooSyncState {
  entity     String    @id
  cursor     String? // ISO timestamp of the newest record synced so far
  lastRunAt  DateTime?
  lastResult Json?
  updatedAt  DateTime  @updatedAt
}

// Granular, admin-editable INTERNAL payment methods (shown on invoice/packing).
// Each maps to a fixed customer-facing method (`customerCode`, see CUSTOMER_METHODS
// in payment-method-service.ts). `courier` qualifies the COD variants (auto-derive).
// `sourceAliases` are raw WooCommerce payment_method strings used to classify
// imported orders. Order.systemPaymentMethod stores this `code`.
model SystemPaymentMethod {
  id            String   @id @default(cuid())
  code          String   @unique
  labelEn       String
  labelAr       String?
  customerCode  String // → a customer-facing method code
  courier       String? // OWN | SMSA | ARAMEX (COD variants), else null
  sourceAliases String[] // raw Woo payment_method strings → this method
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Editable behavior for the fixed 8 order-status codes (STAT). `customerCode` is
// what the shopper sees (null = invisible, e.g. EDIT keeps the previous status).
// Effects are applied idempotently on transition; `allowedNext` drives the
// quick-action buttons; `sourceAliases` classify imported WC/EV statuses.
model OrderStatusConfig {
  id                String   @id @default(cuid())
  code              String   @unique // PENDING | EDIT | HOLD | CONFIRMED | SHIPPED | DELIVERED | CANCELLED | REFUNDED
  labelEn           String
  labelAr           String?
  customerCode      String? // customer-facing code; null = no change (EDIT)
  icon              String   @default("circle") // Lucide icon name
  stockEffect       String   @default("none") // none | restock
  paymentEffect     String   @default("none") // none | paid | refunded
  revenueEffect     String   @default("none") // none | realize | reverse
  loyaltyEffect     String   @default("none") // none | credit | reverse
  notifyAudience    String   @default("none") // none | customer | staff | both
  notifyTemplateKey String?
  allowedNext       String[] // codes reachable from this status
  sourceAliases     String[] // raw WC/EV status strings → this code
  sortOrder         Int      @default(0)
  active            Boolean  @default(true)
  isDefault         Boolean  @default(false) // status new orders start in
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Per-tier product behavior keyed by category/tag/attribute (FR-PRC-03).
model TierProductRule {
  id                 String         @id @default(cuid())
  tierId             String
  tier               Tier           @relation(fields: [tierId], references: [id], onDelete: Cascade)
  matchType          TierRuleMatch
  matchValue         String // category/tag/attribute id or key
  effect             TierRuleEffect
  priceModifierType  DiscountType?
  priceModifierValue Int?
  visible            Boolean?
  available          Boolean?
  createdAt          DateTime       @default(now())

  @@index([tierId])
}

model LoyaltyTransaction {
  id         String         @id @default(cuid())
  customerId String
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  points     Int // signed
  type       LoyaltyTxnType
  orderId    String?
  order      Order?         @relation(fields: [orderId], references: [id])
  note       String?
  expiresAt  DateTime?
  createdAt  DateTime       @default(now())

  @@index([customerId])
}

model Referral {
  id        String    @id @default(cuid())
  inviterId String
  inviter   Customer  @relation("ReferralInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  inviteeId String?   @unique
  invitee   Customer? @relation("ReferralInvitee", fields: [inviteeId], references: [id])
  code      String    @unique
  status    String    @default("pending")
  createdAt DateTime  @default(now())

  @@index([inviterId])
}

// Advanced coupon engine (FR-PRC-07).
model Coupon {
  id               String             @id @default(cuid())
  code             String             @unique
  type             DiscountType
  value            Int // percent points or fixed piastres depending on type
  minSpendPiastres BigInt?
  firstOrderOnly   Boolean            @default(false)
  singleUse        Boolean            @default(false)
  usageLimit       Int?
  perCustomerLimit Int?
  stackable        Boolean            @default(true)
  categoryId       String?
  tierId           String?
  startsAt         DateTime?
  endsAt           DateTime?
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  redemptions      CouponRedemption[]
}

model CouponRedemption {
  id             String    @id @default(cuid())
  couponId       String
  coupon         Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  orderId        String
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amountPiastres BigInt
  createdAt      DateTime  @default(now())

  @@index([couponId])
}

// ============================================================================
// Catalog: brand, category, tag, attribute, product, images, relations
// ============================================================================

model Brand {
  id                  String    @id @default(cuid())
  slug                String    @unique
  slugAr              String?   @unique
  nameEn              String
  nameAr              String?
  descriptionEn       String?
  descriptionAr       String?
  logoUrl             String?
  bannerUrl           String?
  // SEO/AEO (FR-SEO-07)
  metaTitleEn         String?
  metaTitleAr         String?
  metaDescEn          String?
  metaDescAr          String?
  // Full SEO module (RankMath-style editor — same set as Product)
  focusKeywordEn      String?
  focusKeywordAr      String?
  secondaryKeywordsEn String?
  secondaryKeywordsAr String?
  ogTitleEn           String?
  ogTitleAr           String?
  ogDescEn            String?
  ogDescAr            String?
  ogImage             String?
  canonicalUrl        String?
  robotsIndex         Boolean   @default(true)
  robotsFollow        Boolean   @default(true)
  schemaOverridesJson Json?
  legacyName          String?
  products            Product[]
  archivedAt          DateTime?
  createdAt           DateTime  @default(now())
}

model Category {
  id                  String     @id @default(cuid())
  slug                String     @unique
  slugAr              String?    @unique
  nameEn              String
  nameAr              String?
  descriptionEn       String?
  descriptionAr       String?
  imageUrl            String?
  parentId            String?
  parent              Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children            Category[] @relation("CategoryTree")
  metaTitleEn         String?
  metaTitleAr         String?
  metaDescEn          String?
  metaDescAr          String?
  // Full SEO module (RankMath-style editor — same set as Product)
  focusKeywordEn      String?
  focusKeywordAr      String?
  secondaryKeywordsEn String?
  secondaryKeywordsAr String?
  ogTitleEn           String?
  ogTitleAr           String?
  ogDescEn            String?
  ogDescAr            String?
  ogImage             String?
  canonicalUrl        String?
  robotsIndex         Boolean    @default(true)
  robotsFollow        Boolean    @default(true)
  schemaOverridesJson Json?
  products            Product[]  @relation("ProductCategories")
  archivedAt          DateTime?
  createdAt           DateTime   @default(now())

  @@index([parentId])
}

model Tag {
  id         String    @id @default(cuid())
  slug       String    @unique
  nameEn     String
  nameAr     String?
  products   Product[] @relation("ProductTags")
  archivedAt DateTime?
}

model Attribute {
  id            String             @id @default(cuid())
  key           String             @unique
  nameEn        String
  nameAr        String?
  kind          ProductKind        @default(SUPPLEMENT) // LEGACY single applies-to; superseded by `kinds`
  kinds         ProductKind[]      @default([]) // multi-type "applies to" (V3-ATTR)
  inputType     AttributeInputType @default(SINGLE_SELECT) // SINGLE_SELECT | MULTI_SELECT
  descriptionEn String? // admin helper text / purpose
  descriptionAr String?
  unit          String? // optional unit for numeric/measured attributes (mg, ml, …)
  isFilterable  Boolean            @default(false) // drives storefront PLP facets
  isRequired    Boolean            @default(false)
  values        AttributeValue[]
  archivedAt    DateTime?
}

model AttributeValue {
  id          String                  @id @default(cuid())
  attributeId String
  attribute   Attribute               @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  valueEn     String
  valueAr     String?
  slug        String? // filter-URL slug (auto from valueEn, editable)
  sortOrder   Int                     @default(0)
  products    ProductAttributeValue[]

  @@unique([attributeId, valueEn])
}

model Product {
  id                String            @id @default(cuid())
  sku               String            @unique
  legacyWpId        Int?              @unique
  legacySku         String?
  syncedAt          DateTime? // last WooCommerce sync write; sync detaches when updatedAt drifts past this
  gtin              String?
  kind              ProductKind       @default(SUPPLEMENT)
  nameEn            String
  nameAr            String?
  slugEn            String            @unique
  slugAr            String?           @unique
  shortDescEn       String?
  shortDescAr       String?
  longDescEn        String?
  longDescAr        String?
  brandId           String?
  brand             Brand?            @relation(fields: [brandId], references: [id])
  weightG           Int?
  basePricePiastres BigInt            @default(0)
  status            ProductStatus     @default(PUBLISHED)
  preorderEnabled   Boolean           @default(false) // shown on storefront even when out of stock (pre-order / special order)
  productType       OrderProductType? // merchandising tag (FR-ORD-05 list reused)

  // Health duration calculator inputs (FR-HEALTH-01 / FR-REPL-01)
  servingsPerUnit     Int?
  dailyDosage         Int? // min daily dose (also the calculator default)
  dailyDosageMax      Int? // optional upper bound of the dose range
  defaultSupplierHint String?

  // Sourcing (internal) + merchandising flag
  maleSupport       Boolean @default(false) // dedicated Yes/No flag (independent of productType)
  purchaseUrl       String? // supplier/source link (admin only)
  originCountry     String? // 'USA' | 'UK' | 'EU' — import origin (shown as a trust badge)
  purchaseCostMinor Int? // purchase price in MINOR units of the origin currency (cents/pence)
  purchaseCurrency  String? // 'USD' | 'GBP' | 'EUR' — auto-derived from originCountry

  // AI-generated review summary (FR-REV-04) — cached, regenerated on demand
  aiReviewSummary   String?
  aiReviewSummaryAt DateTime?

  // Restriction profile — all default OFF until legal review (FR-RES-01)
  restricted           Boolean @default(false)
  restrictHideCatalog  Boolean @default(false)
  restrictHideFeeds    Boolean @default(false)
  restrictDisableCards Boolean @default(false)
  restrictRequireLogin Boolean @default(false)
  restrictTierGateId   String?
  restrictAgeConsent   Boolean @default(false)

  // SEO/AEO per locale (FR-SEO-07)
  metaTitleEn String?
  metaTitleAr String?
  metaDescEn  String?
  metaDescAr  String?
  aiSummaryEn String?
  aiSummaryAr String?
  faqJson     Json?
  jsonLd      Json?

  // Full SEO module (RankMath-style editor) — bilingual focus keywords, social
  // meta, indexing controls, and editable Product JSON-LD overrides.
  focusKeywordEn      String?
  focusKeywordAr      String?
  secondaryKeywordsEn String? // comma-separated
  secondaryKeywordsAr String?
  ogTitleEn           String?
  ogTitleAr           String?
  ogDescEn            String?
  ogDescAr            String?
  ogImage             String? // social share image URL (falls back to the first product image)
  canonicalUrl        String?
  robotsIndex         Boolean @default(true)
  robotsFollow        Boolean @default(true)
  schemaOverridesJson Json? // merged over the auto-generated Product schema

  // Aggregates (denormalized for listing perf; recomputed on review write)
  ratingAvg   Float? @default(0)
  ratingCount Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images           ProductImage[]
  categories       Category[]              @relation("ProductCategories")
  tags             Tag[]                   @relation("ProductTags")
  attributeValues  ProductAttributeValue[]
  lots             Lot[]
  reviews          Review[]
  questions        ProductQuestion[]
  wishlistItems    WishlistItem[]
  compareItems     CompareItem[]
  orderItems       OrderItem[]
  changeEvents     ProductChangeEvent[]
  relationsFrom    ProductRelation[]       @relation("RelationFrom")
  relationsTo      ProductRelation[]       @relation("RelationTo")
  stocktakeCounts  StocktakeCount[]
  specialOrders    SpecialOrder[]
  collections      Collection[]            @relation("ProductCollections")
  purchaseRequests PurchaseRequest[]
  reorderIgnore    ReorderIgnore?

  @@index([brandId])
  @@index([status])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  @@index([productId])
}

model ProductAttributeValue {
  productId        String
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeValueId String
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([productId, attributeValueId])
  @@index([attributeValueId])
}

// Related / upsell / cross-sell (FR-CAT-04)
model ProductRelation {
  id        String         @id @default(cuid())
  fromId    String
  from      Product        @relation("RelationFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toId      String
  to        Product        @relation("RelationTo", fields: [toId], references: [id], onDelete: Cascade)
  kind      RelationKind   @default(RELATED)
  source    RelationSource @default(MANUAL)
  sortOrder Int            @default(0)

  @@unique([fromId, toId, kind])
  @@index([fromId])
}

// ============================================================================
// Inventory: location, lot, reservation, movement ledger (FR-INV-*, FR-STK-*)
// ============================================================================

model Location {
  id                String             @id @default(cuid())
  name              String
  type              String             @default("warehouse")
  isUltraFastZone   Boolean            @default(false)
  lots              Lot[]
  movements         MovementLedger[]
  stocktakeSessions StocktakeSession[]
  stocktakeCounts   StocktakeCount[]
  createdAt         DateTime           @default(now())
}

model Lot {
  id                    String    @id @default(cuid())
  productId             String
  product               Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId            String
  location              Location  @relation(fields: [locationId], references: [id])
  expiryDate            DateTime? // null = non-perishable / no expiry (NA); sorts last in FEFO
  qtyOnHand             Int       @default(0)
  qtyReserved           Int       @default(0)
  costPiastres          BigInt?
  priceOverridePiastres BigInt? // price-per-expiry (FR-INV-04)
  condition             String    @default("NEW") // NEW | OPEN_BOX | DAMAGED | BROKEN — non-NEW sells as an explicit buy-box variant
  saleFlag              Boolean   @default(false)
  sourceBatchId         String? // YeldnIN batch for revenue/COGS attribution (FR-INT-04)
  receivedAt            DateTime  @default(now())
  status                LotStatus @default(LIVE)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  reservations    LotReservation[]
  orderItems      OrderItem[]
  movements       MovementLedger[]
  stocktakeCounts StocktakeCount[]

  @@index([productId, expiryDate])
  @@index([status])
}

model LotReservation {
  id        String   @id @default(cuid())
  lotId     String
  lot       Lot      @relation(fields: [lotId], references: [id], onDelete: Cascade)
  orderId   String?
  sessionId String?
  qty       Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([lotId])
}

model MovementLedger {
  id         String       @id @default(cuid())
  lotId      String
  lot        Lot          @relation(fields: [lotId], references: [id], onDelete: Cascade)
  locationId String
  location   Location     @relation(fields: [locationId], references: [id])
  type       MovementType
  qtyDelta   Int
  reason     String?
  refType    String?
  refId      String?
  createdAt  DateTime     @default(now())

  @@index([lotId])
}

// ============================================================================
// Shipping zones & types (FR-SHP-*)
// ============================================================================

model ShippingZone {
  id          String          @id @default(cuid())
  name        String
  governorate String
  granularity ZoneGranularity @default(GOVERNORATE)
  areas       ShippingArea[]
  createdAt   DateTime        @default(now())
}

model ShippingArea {
  id                 String       @id @default(cuid())
  zoneId             String
  zone               ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name               String
  allowsUltraFast    Boolean      @default(false)
  allowsPos          Boolean      @default(false) // POS-on-Delivery eligible (Greater Cairo)
  etaText            String?
  shippingTypesJson  Json? // available types for this area
  courierMappingJson Json? // type -> courier suggestion for Ops
  createdAt          DateTime     @default(now())

  @@index([zoneId])
}

// Customer-facing shipping types + fees — seeded defaults, admin-configurable (FR-SHP-07).
model ShippingTypeConfig {
  id          String       @id @default(cuid())
  type        ShippingType @unique
  feePiastres BigInt       @default(0)
  enabled     Boolean      @default(true)
  labelEn     String
  labelAr     String
}

// ============================================================================
// Orders, items, gifts, special orders (FR-ORD-*, FR-SPO-*)
// ============================================================================

model Order {
  id                  String       @id @default(cuid())
  number              String       @unique
  customerId          String?
  customer            Customer?    @relation(fields: [customerId], references: [id])
  guestEmail          String?
  status              String       @default("PENDING") // OrderStatusConfig.code (system/internal)
  customerStatus      String? // customer-facing code (derived; EDIT keeps previous)
  legacyStatus        String? // raw source status (WooCommerce/EV) for re-mapping
  reviewRequestSentAt DateTime? // #188: set once a post-delivery review request has been sent/attempted
  paymentMethod       String? // customer-facing method code (checkout) — CUSTOMER_METHODS
  systemPaymentMethod String? // SystemPaymentMethod.code (granular; invoice/packing)
  legacyPaymentMethod String? // raw source payment_method (WooCommerce) for re-mapping
  paymentState        PaymentState @default(PENDING)
  payCheck            PayCheck     @default(NO)

  subtotalPiastres     BigInt  @default(0)
  discountPiastres     BigInt  @default(0)
  shippingPiastres     BigInt  @default(0)
  totalPiastres        BigInt  @default(0)
  depositPaidPiastres  BigInt?
  balanceDuePiastres   BigInt?
  compensationPiastres BigInt?

  pharmacistId      String?
  pharmacist        User?              @relation("OrderPharmacist", fields: [pharmacistId], references: [id])
  source            String?
  utmJson           Json?
  customerOrderType CustomerOrderType?
  orderProductType  OrderProductType?

  shippingType        ShippingType?
  courier             CourierKind?
  trackingNumber      String?
  shippingAddressId   String?
  shippingAddress     Address?      @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id])
  // Immutable delivery-address snapshot (supports guest checkout).
  shippingAddressJson Json?
  riskScore           Int?
  discreetPackaging   Boolean       @default(false)
  isSpecialOrder      Boolean       @default(false)
  isPreorder          Boolean       @default(false) // contains pre-order lines → deposit taken, balance due on delivery

  legacyWpId Int?      @unique
  syncedAt   DateTime? // last WooCommerce sync write (detach detection)
  placedAt   DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  items             OrderItem[]
  gifts             OrderGift[]
  specialOrder      SpecialOrder?
  returns           Return[]
  couponRedemptions CouponRedemption[]
  loyaltyTxns       LoyaltyTransaction[]

  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id                String       @id @default(cuid())
  orderId           String
  order             Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId         String
  product           Product      @relation(fields: [productId], references: [id])
  lotId             String?
  lot               Lot?         @relation(fields: [lotId], references: [id])
  qty               Int
  unitPricePiastres BigInt
  lineExpiry        DateTime? // exact expiry of bound lot travels with the line (FR-INV-02)
  condition         String? // bound lot's condition snapshot (null = NEW / pre-feature)
  preorder          Boolean      @default(false) // awaiting stock: no lot bound, no stock decrement, no revenue until fulfilled
  weightG           Int?
  pointsEarned      Int          @default(0)
  isGift            Boolean      @default(false)
  lost              Boolean      @default(false) // marked LOST: excluded from totals/revenue, no restock
  lostAt            DateTime?
  lostReason        String?
  returnItems       ReturnItem[]

  @@index([orderId])
  @@index([productId])
}

// Gifts: separate inventory, hidden from customer everywhere (FR-ORD-10)
model Gift {
  id           String         @id @default(cuid())
  code         String         @unique // Gx-*
  internalName String
  stock        Int            @default(0)
  expiry       DateTime?
  costPiastres BigInt?
  archivedAt   DateTime?
  createdAt    DateTime       @default(now())
  orderGifts   OrderGift[]
  movements    GiftMovement[]
}

/// Gift stock movement audit (counter-based — gifts are NOT lot-tracked).
/// GRANT = added to an order (negative), RETURN = restocked (positive),
/// ADJUST = manual stock edit from the gift form (delta).
model GiftMovement {
  id        String   @id @default(cuid())
  giftId    String
  gift      Gift     @relation(fields: [giftId], references: [id], onDelete: Cascade)
  type      String // GRANT | RETURN | ADJUST
  qtyDelta  Int
  refType   String? // 'order' | 'order_edit' | 'status_restock' | 'manual'
  refId     String?
  note      String?
  createdAt DateTime @default(now())

  @@index([giftId, createdAt])
  @@index([refType, refId])
}

model OrderGift {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  giftId  String
  gift    Gift   @relation(fields: [giftId], references: [id])
  qty     Int    @default(1)

  @@index([orderId])
}

model SpecialOrder {
  id                   String             @id @default(cuid())
  // A request is a standalone lead; an Order is linked once it converts.
  orderId              String?            @unique
  order                Order?             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId           String?
  customer             Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  productId            String?
  product              Product?           @relation(fields: [productId], references: [id])
  requestedProductText String?
  productUrl           String?
  requesterName        String?
  requesterPhone       String?
  requesterEmail       String?
  notes                String?
  yeldnRequestUid      String?            @unique
  slaType              String? // Fast 20d / Manufacturer 30d / Injection 40d
  deadlineAt           DateTime?
  status               SpecialOrderStatus @default(REQUESTED)
  milestonesJson       Json?
  compensationPiastres BigInt?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([customerId])
  @@index([status])
}

// ============================================================================
// Wishlist & compare (FR-WSH-*, FR-CMP-*)
// ============================================================================

model WishlistList {
  id         String         @id @default(cuid())
  customerId String
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String         @default("My Wishlist")
  isDefault  Boolean        @default(false)
  isPublic   Boolean        @default(false)
  shareToken String?        @unique
  items      WishlistItem[]
  createdAt  DateTime       @default(now())

  @@index([customerId])
}

model WishlistItem {
  id                String       @id @default(cuid())
  listId            String
  list              WishlistList @relation(fields: [listId], references: [id], onDelete: Cascade)
  productId         String
  product           Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  notifyPriceDrop   Boolean      @default(true)
  notifyBackInStock Boolean      @default(true)
  addedAt           DateTime     @default(now())

  @@unique([listId, productId])
  @@index([productId])
}

model CompareList {
  id         String        @id @default(cuid())
  customerId String?       @unique
  customer   Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sessionId  String?       @unique
  items      CompareItem[]
  createdAt  DateTime      @default(now())
}

model CompareItem {
  id        String      @id @default(cuid())
  listId    String
  list      CompareList @relation(fields: [listId], references: [id], onDelete: Cascade)
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([listId, productId])
}

// ============================================================================
// Product change events + analytics (FR-WSH alerts, FR-BEH-*)
// ============================================================================

model ProductChangeEvent {
  id        String            @id @default(cuid())
  productId String
  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      ProductChangeType
  oldValue  String?
  newValue  String?
  createdAt DateTime          @default(now())

  @@index([productId])
}

model AnalyticsSession {
  id             String           @id @default(cuid())
  sessionId      String           @unique
  customerId     String?
  customer       Customer?        @relation(fields: [customerId], references: [id])
  utmJson        Json?
  referrer       String?
  location       String?
  userAgent      String?
  // Visitor enrichment (Analytics P1) — captured server-side, only under full
  // consent. `ip` is raw (owner opted in); `ipTruncated` is the anonymized form
  // (last IPv4 octet / IPv6 suffix zeroed) used wherever the raw IP isn't needed.
  ip             String?
  ipTruncated    String?
  country        String?
  region         String?
  city           String?
  os             String?
  osVersion      String?
  browser        String?
  browserVersion String?
  deviceType     String? // mobile | tablet | desktop | bot
  isBot          Boolean          @default(false)
  language       String?
  screenW        Int?
  screenH        Int?
  viewportW      Int?
  viewportH      Int?
  landingPath    String?
  exitPath       String?
  lastSeenAt     DateTime?
  startedAt      DateTime         @default(now())
  events         AnalyticsEvent[]

  @@index([startedAt])
  @@index([country])
  @@index([deviceType])
  @@index([isBot])
}

model AnalyticsEvent {
  id         String            @id @default(cuid())
  sessionId  String?
  session    AnalyticsSession? @relation(fields: [sessionId], references: [sessionId])
  customerId String?
  customer   Customer?         @relation(fields: [customerId], references: [id])
  type       String // page_view, product_view, search, cart_add, ...
  path       String?
  durationMs Int? // dwell time on the page (page_leave events)
  propsJson  Json?
  createdAt  DateTime          @default(now())

  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================================
// Reviews (FR-REV-*)
// ============================================================================

model Review {
  id               String        @id @default(cuid())
  productId        String
  product          Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId       String?
  customer         Customer?     @relation(fields: [customerId], references: [id])
  authorName       String?
  rating           Int
  title            String?
  body             String?
  status           ReviewStatus  @default(PENDING)
  source           ReviewSource  @default(NATIVE)
  verifiedPurchase Boolean       @default(false)
  moderatorId      String?
  moderator        User?         @relation("ReviewModerator", fields: [moderatorId], references: [id])
  legacyId         String?
  media            ReviewMedia[]
  createdAt        DateTime      @default(now())

  @@index([productId])
}

model ReviewMedia {
  id       String    @id @default(cuid())
  reviewId String
  review   Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url      String
  type     MediaType @default(IMAGE)
}

// Customer product Q&A ("Answered Questions", audit follow-up). Questions land
// PENDING; staff answer + publish. Only PUBLISHED pairs render on the PDP.
model ProductQuestion {
  id         String    @id @default(cuid())
  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId String?
  askerName  String?
  question   String
  answer     String?
  status     String    @default("PENDING") // PENDING | PUBLISHED | HIDDEN
  createdAt  DateTime  @default(now())
  answeredAt DateTime?

  @@index([productId, status])
  @@index([status])
}

// ============================================================================
// Returns (FR-RET-*)
// ============================================================================

model Return {
  id             String        @id @default(cuid())
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  reasonCode     String // denormalized reason label snapshot (kept readable even if the reason is renamed/deactivated)
  reasonId       String? // managed ReturnReason (null for legacy free-text returns)
  reason         ReturnReason? @relation(fields: [reasonId], references: [id])
  reasonNote     String? // free text for the "Other" reason or a required sub-detail
  status         ReturnStatus  @default(REQUESTED)
  refundMethod   String?
  refundPiastres BigInt?
  items          ReturnItem[]
  createdAt      DateTime      @default(now())

  @@index([orderId])
  @@index([reasonId])
}

/// Managed, bilingual return reasons (FR-RET). Admins add/edit/reorder/deactivate
/// these without a deploy; the return-creation dropdown reads active ones ordered
/// by sortOrder. Soft-deactivate (active=false) rather than delete so historical
/// returns keep their reason. `requiresDetail` reasons ("Product issue", "Other")
/// reveal a free-text sub-detail field at creation.
model ReturnReason {
  id             String   @id @default(cuid())
  labelEn        String
  labelAr        String
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  requiresDetail Boolean  @default(false)
  returns        Return[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([active, sortOrder])
}

model ReturnItem {
  id          String            @id @default(cuid())
  returnId    String
  return      Return            @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItemId String
  orderItem   OrderItem         @relation(fields: [orderItemId], references: [id])
  qty         Int
  disposition ReturnDisposition @default(PENDING)
}

// ============================================================================
// Stocktake (FR-STK-*)
// ============================================================================

model StocktakeSession {
  id           String           @id @default(cuid())
  name         String
  locationId   String
  location     Location         @relation(fields: [locationId], references: [id])
  phase        StocktakePhase   @default(FORWARD)
  status       StocktakeStatus  @default(OPEN)
  snapshotJson Json?
  startedAt    DateTime         @default(now())
  closedAt     DateTime?
  counts       StocktakeCount[]
}

model StocktakeCount {
  id             String           @id @default(cuid())
  sessionId      String
  session        StocktakeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId      String
  product        Product          @relation(fields: [productId], references: [id])
  lotId          String?
  lot            Lot?             @relation(fields: [lotId], references: [id])
  locationId     String
  location       Location         @relation(fields: [locationId], references: [id])
  expectedQty    Int
  countedQty     Int?
  varianceReason String?
  countedById    String?
  countedBy      User?            @relation(fields: [countedById], references: [id])
  countedAt      DateTime?

  @@index([sessionId])
}

// ============================================================================
// Play: quizzes & games (FR-PLAY-01, FR-QUIZ-01)
// ============================================================================

model Quiz {
  id            String      @id @default(cuid())
  slug          String      @unique
  titleEn       String
  titleAr       String?
  kind          QuizKind    @default(FUN)
  questionsJson Json?
  published     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  entries       PlayEntry[]
}

model Game {
  id         String      @id @default(cuid())
  slug       String      @unique
  titleEn    String
  titleAr    String?
  configJson Json?
  published  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  entries    PlayEntry[]
}

model PlayEntry {
  id         String    @id @default(cuid())
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  quizId     String?
  quiz       Quiz?     @relation(fields: [quizId], references: [id])
  gameId     String?
  game       Game?     @relation(fields: [gameId], references: [id])
  resultJson Json?
  createdAt  DateTime  @default(now())
}

// ============================================================================
// Content: CMS, blog, redirects, notification templates (FR-CMS-*, FR-SEO-*, FR-NOT-*)
// ============================================================================

model CmsPage {
  id          String        @id @default(cuid())
  slug        String        @unique
  titleEn     String
  titleAr     String?
  bodyEn      String?
  bodyAr      String?
  status      ContentStatus @default(DRAFT)
  metaTitleEn String?
  metaTitleAr String?
  metaDescEn  String?
  metaDescAr  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model BlogPost {
  id          String        @id @default(cuid())
  slug        String        @unique
  titleEn     String
  titleAr     String?
  excerptEn   String?
  excerptAr   String?
  bodyEn      String?
  bodyAr      String?
  coverImage  String? // card thumbnail (blog listing + homepage section)
  authorName  String? // pharmacist byline
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  metaTitleEn String?
  metaTitleAr String?
  metaDescEn  String?
  metaDescAr  String?
  legacyWpId  Int?          @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Redirect {
  id         String   @id @default(cuid())
  fromPath   String   @unique
  toPath     String
  statusCode Int      @default(301)
  createdAt  DateTime @default(now())
}

// Curated collections (Bestsellers, Offers, Devices…) — manual picks or an
// auto rule by category/tag (FR-CAT-03). Resolved to products at query time.
model Collection {
  id             String         @id @default(cuid())
  slug           String         @unique
  titleEn        String
  titleAr        String?
  descriptionEn  String?
  descriptionAr  String?
  type           CollectionType @default(MANUAL)
  ruleCategoryId String?
  ruleTagSlug    String?
  ruleJson       Json? // structured condition builder (V3-COL-4): { match: 'ALL'|'ANY', conditions: [...] }
  manualOrder    String[]       @default([]) // ordered product ids for MANUAL collections (membership stays in the M2M)
  imageUrl       String?
  imageAltEn     String? // banner alt text (a11y + SEO)
  imageAltAr     String?
  status         ContentStatus  @default(DRAFT)
  sortOrder      Int            @default(0)
  metaTitleEn    String?
  metaTitleAr    String?
  metaDescEn     String?
  metaDescAr     String?
  products       Product[]      @relation("ProductCollections")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model NotificationTemplate {
  id            String              @id @default(cuid())
  key           String
  channel       NotificationChannel
  locale        String
  subject       String?
  body          String
  variablesJson Json?
  updatedAt     DateTime            @updatedAt

  @@unique([key, channel, locale])
}

// Per-notification record + dispatch outcome (FR-NOT-*)
model Notification {
  id          String              @id @default(cuid())
  customerId  String?
  customer    Customer?           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel     NotificationChannel
  templateKey String
  toAddress   String?
  subject     String?
  body        String
  status      NotificationStatus  @default(PENDING)
  error       String?
  refType     String?
  refId       String?
  createdAt   DateTime            @default(now())
  sentAt      DateTime?

  @@index([customerId])
  @@index([status])
}

// Per-customer channel + category opt-ins (FR-NOT-03)
model NotificationPreference {
  id           String   @id @default(cuid())
  customerId   String   @unique
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  email        Boolean  @default(true)
  push         Boolean  @default(true)
  orderUpdates Boolean  @default(true)
  priceDrop    Boolean  @default(true)
  backInStock  Boolean  @default(true)
  marketing    Boolean  @default(false)
  updatedAt    DateTime @updatedAt
}

// Web Push subscriptions (FR-NOT-02, PWA)
model PushSubscription {
  id         String    @id @default(cuid())
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  endpoint   String    @unique
  p256dh     String
  auth       String
  createdAt  DateTime  @default(now())

  @@index([customerId])
}

// ============================================================================
// Platform: audit log, integration clients (FR-MCP-*, FR-INT-*)
// ============================================================================

model AuditLog {
  id         String    @id @default(cuid())
  actorType  ActorType @default(SYSTEM)
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  dataJson   Json?
  ip         String?
  createdAt  DateTime  @default(now())

  @@index([entityType, entityId])
}

// Scoped API clients for YeldnIN integration + Claude/ChatGPT MCP (FR-MCP-01,
// FR-INT-01). For AI_MCP clients this is the "API key": secretHash = sha256 of
// the bearer token (shown once), scopesJson = granted scopes, keyPrefix = a
// non-secret head for display.
model IntegrationClient {
  id          String          @id @default(cuid())
  clientId    String          @unique
  name        String
  secretHash  String
  kind        IntegrationKind
  scopesJson  Json?
  keyPrefix   String? // non-secret leading chars of the token, for identification
  active      Boolean         @default(false)
  lastUsedAt  DateTime?
  createdById String?
  createdAt   DateTime        @default(now())
}

// Staged AI writes (FR-MCP-03). The MCP write endpoint never mutates live data;
// it records a proposal here for a human to approve (→ applied) or reject.
enum AiProposalStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
  FAILED
}

model AiProposal {
  id           String           @id @default(cuid())
  clientId     String? // IntegrationClient.id that proposed it (soft ref)
  clientName   String?
  action       String // whitelisted action key, e.g. "product.update"
  entityType   String
  entityId     String?
  payloadJson  Json
  status       AiProposalStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  resultJson   Json? // applied summary or failure reason
  note         String?
  createdAt    DateTime         @default(now())

  @@index([status])
}

// YeldnIN integration plumbing (P14, INTEGRATION_CONTRACT). Outbound events use
// the outbox pattern; inbound webhooks are deduped by idempotency key + nonce.
enum OutboxStatus {
  PENDING
  SENT
  FAILED
  DEAD
}

model OutboxEvent {
  id            String       @id @default(cuid())
  type          String // products.upsert, requests.create, revenue.event, deliveries.create
  aggregateId   String? // request uid / order id — same aggregate delivered in order
  payloadJson   Json
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  lastError     String?
  createdAt     DateTime     @default(now())
  nextAttemptAt DateTime?
  sentAt        DateTime?

  @@index([status])
  @@index([aggregateId])
}

/// Local reorder request captured by the Inventory "Requests (To-buy)" feature
/// (INV-P2). Queued to an OutboxEvent for YeldnIN dispatch once the integration
/// is enabled; until then it records intent + drives the local "requested"
/// count on the To-buy list. Status: PENDING | SENT | FULFILLED | CANCELLED.
model PurchaseRequest {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  qtyRequested    Int
  status          String   @default("PENDING")
  note            String?
  requestedById   String? // acting staff user id (no FK — mirrors AuditLog.actorId)
  requestedByName String? // snapshot for display; survives staff deletion
  outboxEventId   String? // the OutboxEvent enqueued for YeldnIN (null until dispatched)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([productId])
  @@index([status])
}

/// Products dismissed from the To-buy lists (INV-P2). Suppresses a product while
/// the snooze is active AND stock hasn't risen materially above the level when
/// it was ignored (logic in inventory-reorder-service). One row per product.
model ReorderIgnore {
  id            String    @id @default(cuid())
  productId     String    @unique
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  snoozeUntil   DateTime? // null = indefinite
  stockAtIgnore Int? // stock when ignored; a rise above this resurfaces the product
  reason        String?
  ignoredById   String?
  ignoredByName String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/// Merchandising fix for search queries that return nothing (#186). A normalized
/// query either REWRITEs to different search terms (so it finds results) or
/// REDIRECTs the searcher to a page (product/category/collection/URL).
model SearchRule {
  id          String   @id @default(cuid())
  query       String   @unique // normalized: lowercased, trimmed, spaces collapsed
  kind        String   @default("REWRITE") // REWRITE | REDIRECT
  rewriteTo   String? // REWRITE: search terms to use instead
  targetUrl   String? // REDIRECT: locale-relative path to send the searcher to
  note        String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IdempotencyRecord {
  id           String   @id @default(cuid())
  key          String   @unique
  endpoint     String
  statusCode   Int
  responseJson Json?
  createdAt    DateTime @default(now())
}

model IntegrationNonce {
  nonce     String   @id
  clientId  String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Admin-configurable business constants (AGENTS.md rule #2 — never hard-code).
// Simple key/value store; typed + defaulted in src/lib/settings-service.ts.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

// Social media links shown in the footer (FR-SF). Admin-managed, ordered.
model SocialLink {
  id        String   @id @default(cuid())
  platform  String // instagram | facebook | x | tiktok | youtube | linkedin | whatsapp | snapchat | other
  label     String?
  url       String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Editable homepage testimonials + trust badges (admin-managed, ordered).
model HomeTestimonial {
  id        String   @id @default(cuid())
  quoteEn   String
  quoteAr   String?
  name      String
  location  String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model HomeTrustBadge {
  id        String   @id @default(cuid())
  labelEn   String
  labelAr   String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
