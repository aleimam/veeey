# Veeey — environment variables (P0). Copy to .env and fill in.
# NEVER commit real secrets. Money is EGP integer piastres (no currency env needed).

# --- Core ---
NODE_ENV="development"
NEXT_PUBLIC_SITE_URL="http://localhost:3100"

# --- Database (PostgreSQL) ---
# Prisma reads this via prisma.config.ts (dotenv). A live DB is not required to
# build; it's needed for `prisma migrate` / runtime data access (P1+).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/veeey?schema=public"

# --- Auth.js (NextAuth v5) ---
# Generate: `npx auth secret`  (providers wired in P2)
AUTH_SECRET=""
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_APPLE_ID=""
# AUTH_APPLE_SECRET=""
# AUTH_FACEBOOK_ID=""
# AUTH_FACEBOOK_SECRET=""
# AUTH_TWITTER_ID=""
# AUTH_TWITTER_SECRET=""

# --- reCAPTCHA v3 (FR-ACC-01; verification bypassed when unset) ---
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
# RECAPTCHA_SECRET_KEY=""
# RECAPTCHA_MIN_SCORE="0.5"

# --- Feature flags (default OFF) ---
INTEGRATION_ENABLED="false"     # YeldnIN integration — gated, P14
TRANSITION_MIRROR="false"       # Egypt Vitamins parallel-run mirror — gated, P16

# --- YeldnIN integration (P14, after contract re-baseline) ---
# INTEGRATION_CLIENT_VEEEY_SECRET=""   # >=32 chars, shared HMAC secret
# VEEEY_WEBHOOK_URL=""                 # where YeldnIN posts events

# --- Payments (P7) ---
# OPAY_PUBLIC_KEY=""
# OPAY_SECRET_KEY=""
# KASHIER_API_KEY=""

# --- Shipping carriers (P7) ---
# ARAMEX_API_KEY=""
# SMSA_API_KEY=""

# --- Messaging providers (P12) ---
# WHATSAPP_API_TOKEN=""
# SMS_API_KEY=""
# EMAIL_API_KEY=""

# --- Analytics (P5) ---
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
# NEXT_PUBLIC_CLARITY_ID=""

# --- Web Push (PWA notifications, P12) ---
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""

# --- AI (P11: quiz generation + review summaries; env-gated, optional) ---
# --- AI (Claude). Configure in Admin → Providers, OR set these as fallback. ---
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-opus-4-8"

# --- Email (order lifecycle emails). Configure SMTP in Admin → Providers, OR
#     set these as a fallback. Admin SMTP (DB) takes precedence over Resend. ---
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"   # true for port 465
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM_NAME="Veeey"
# RESEND_API_KEY=""     # used only if no SMTP is configured
# EMAIL_FROM="Veeey <info@veeey.com>"

# --- SMS via SMSMisr (sms.com.eg). Configure in Admin → Providers, OR set here. ---
# SMS_USERNAME=""       # SMSMisr console → Settings → APIs Username
# SMS_PASSWORD=""       # SMSMisr console → Settings → API Password
# SMS_SENDER=""         # Sender ID token
# SMS_ENVIRONMENT="2"   # 1=Live, 2=Test
# SMS_LANGUAGE="1"      # 1=English, 2=Arabic, 3=Unicode
# VAPID_SUBJECT="mailto:info@veeey.com"
# JOBS_DISABLED="0"  # set 1 to force inline notification processing (no pg-boss)

# --- SEO + feeds + AI MCP (P13) ---
# NEXT_PUBLIC_SITE_URL="https://veeey.com"
# MCP_API_SECRET=""  # HMAC shared secret for /api/mcp/* (env-gated; unset = disabled)

# --- YeldnIN integration (P14; GATED, ships disabled) ---
# INTEGRATION_ENABLED="0"            # 1 to enable outbound emission + inbound webhook (else 404)
# INTEGRATION_CLIENT_VEEEY_SECRET="" # >=32 chars, shared both directions (HMAC)
# YELDNIN_BASE_URL="http://localhost:4500/api/integration/v1"  # mock in dev
# VEEEY_WEBHOOK_URL="https://veeey.com/api/integration/yeldnin/webhook"
# MOCK_PORT="4500"
